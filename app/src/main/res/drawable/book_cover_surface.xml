<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:angle="135"
                android:endColor="#4B3325"
                android:startColor="#6D4A34" />
        </shape>
    </item>
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="21dp" />
            <stroke android:width="1dp" android:color="#35FFFFFF" />
            <solid android:color="#00000000" />
        </shape>
    </item>
    <item android:gravity="top|end" android:top="20dp" android:right="16dp">
        <shape android:shape="rectangle">
            <size android:width="110dp" android:height="110dp" />
            <gradient
                android:angle="315"
                android:endColor="#00000000"
                android:startColor="#18FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
